@page "/borrow"
@rendermode InteractiveServer
@inject IHttpClientFactory HttpClientFactory
@inject ISnackbar Snackbar

<PageTitle>Borrow a Book</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Borrow a Book</MudText>
<MudText Typo="Typo.body1" Class="mb-4">Select a borrower, choose a book, and set the due date.</MudText>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-4" />
}
else
{
    <MudCard Style="max-width:600px">
        <MudCardContent>
            <MudSelect T="Guid" @bind-Value="_request.BorrowerId" Label="Borrower" Required="true"
                       Variant="Variant.Outlined" Class="mb-4"
                       AnchorOrigin="Origin.BottomLeft">
                @foreach (var b in _borrowers)
                {
                    <MudSelectItem Value="@b.Id">@b.Name</MudSelectItem>
                }
            </MudSelect>

            <MudSelect T="Guid" @bind-Value="_request.BookId" Label="Book" Required="true"
                       Variant="Variant.Outlined" Class="mb-4"
                       AnchorOrigin="Origin.BottomLeft">
                @foreach (var b in _books)
                {
                    <MudSelectItem Value="@b.Id">@b.Title — @b.Author</MudSelectItem>
                }
            </MudSelect>

            <MudDatePicker Label="Valid Until" @bind-Date="_validUntil"
                           MinDate="DateTime.Today.AddDays(1)"
                           Variant="Variant.Outlined" Class="mb-4" />
        </MudCardContent>
        <MudCardActions Class="px-4 pb-4">
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.SwapHoriz"
                       OnClick="SubmitBorrowingAsync"
                       Disabled="_submitting">
                @if (_submitting)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                Confirm Borrowing
            </MudButton>
        </MudCardActions>
    </MudCard>
}

@code {
    private List<Borrower> _borrowers = [];
    private List<Book> _books = [];
    private BorrowingRequest _request = new() { ValidUntil = DateTime.Today.AddDays(14) };
    private DateTime? _validUntil = DateTime.Today.AddDays(14);
    private bool _loading = true;
    private bool _submitting;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("gateway");
            var borrowersTask = client.GetFromJsonAsync<List<Borrower>>("/api/cqrs/v1/borrowers");
            var booksTask = client.GetFromJsonAsync<List<Book>>("/api/cqrs/v1/books");
            _borrowers = await borrowersTask ?? [];
            _books = await booksTask ?? [];
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load data: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SubmitBorrowingAsync()
    {
        if (_request.BorrowerId == Guid.Empty)
        {
            Snackbar.Add("Please select a borrower.", Severity.Warning);
            return;
        }
        if (_request.BookId == Guid.Empty)
        {
            Snackbar.Add("Please select a book.", Severity.Warning);
            return;
        }
        if (_validUntil is null || _validUntil <= DateTime.Today)
        {
            Snackbar.Add("Please select a future due date.", Severity.Warning);
            return;
        }

        _request.ValidUntil = _validUntil.Value;
        _submitting = true;
        try
        {
            var client = HttpClientFactory.CreateClient("gateway");
            var response = await client.PostAsJsonAsync("/api/cqrs/v1/borrowings", _request);
            response.EnsureSuccessStatusCode();
            Snackbar.Add("Borrowing created successfully!", Severity.Success);
            _request = new BorrowingRequest { ValidUntil = DateTime.Today.AddDays(14) };
            _validUntil = DateTime.Today.AddDays(14);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error creating borrowing: {ex.Message}", Severity.Error);
        }
        finally
        {
            _submitting = false;
        }
    }
}
