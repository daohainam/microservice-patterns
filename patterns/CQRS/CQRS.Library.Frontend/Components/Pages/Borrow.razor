@page "/borrow"
@rendermode InteractiveServer
@inject IHttpClientFactory HttpClientFactory
@inject ISnackbar Snackbar
@using CQRS.Library.Frontend.Models

<PageTitle>Borrow a Book</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Borrow a Book</MudText>
<MudText Typo="Typo.body1" Class="mb-4">Search for a borrower and a book, then set the due date.</MudText>

<MudCard Style="max-width:600px">
    <MudCardContent>
        <MudAutocomplete T="Borrower" Label="Borrower" Required="true"
                         @bind-Value="_selectedBorrower"
                         SearchFunc="SearchBorrowersAsync"
                         ToStringFunc="@(b => b?.Name ?? string.Empty)"
                         Variant="Variant.Outlined" Class="mb-4"
                         AdornmentIcon="@Icons.Material.Filled.PersonSearch"
                         Adornment="Adornment.Start"
                         Clearable="true"
                         ResetValueOnEmptyText="true"
                         MinCharacters="0"
                         ShowProgressIndicator="true"
                         Placeholder="Type to search borrowers…" />

        <MudAutocomplete T="Book" Label="Book" Required="true"
                         @bind-Value="_selectedBook"
                         SearchFunc="SearchBooksAsync"
                         ToStringFunc="@(b => b is null ? string.Empty : $"{b.Title} — {b.Author}")"
                         Variant="Variant.Outlined" Class="mb-4"
                         AdornmentIcon="@Icons.Material.Filled.Search"
                         Adornment="Adornment.Start"
                         Clearable="true"
                         ResetValueOnEmptyText="true"
                         MinCharacters="0"
                         ShowProgressIndicator="true"
                         Placeholder="Type to search books…" />

        <MudDatePicker Label="Valid Until" @bind-Date="_validUntil"
                       MinDate="DateTime.Today.AddDays(1)"
                       Variant="Variant.Outlined" Class="mb-4" />
    </MudCardContent>
    <MudCardActions Class="px-4 pb-4">
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.SwapHoriz"
                   OnClick="SubmitBorrowingAsync"
                   Disabled="_submitting">
            @if (_submitting)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            Confirm Borrowing
        </MudButton>
    </MudCardActions>
</MudCard>

@code {
    private Borrower? _selectedBorrower;
    private Book? _selectedBook;
    private DateTime? _validUntil = DateTime.Today.AddDays(14);
    private bool _submitting;

    private List<Borrower> _allBorrowers = [];
    private List<Book> _allBooks = [];
    private bool _dataLoaded;

    protected override async Task OnInitializedAsync()
    {
        await EnsureDataLoadedAsync();
    }

    private async Task EnsureDataLoadedAsync(CancellationToken cancellationToken = default)
    {
        if (_dataLoaded) return;
        try
        {
            var borrowerClient = HttpClientFactory.CreateClient("borrowerService");
            var bookClient = HttpClientFactory.CreateClient("bookService");
            var borrowersTask = borrowerClient.GetFromJsonAsync<List<Borrower>>("/api/cqrs/v1/borrowers", cancellationToken);
            var booksTask = bookClient.GetFromJsonAsync<List<Book>>("/api/cqrs/v1/books", cancellationToken);
            _allBorrowers = await borrowersTask ?? [];
            _allBooks = await booksTask ?? [];
            _dataLoaded = true;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load data: {ex.Message}", Severity.Error);
        }
    }

    private async Task<IEnumerable<Borrower>> SearchBorrowersAsync(string value, CancellationToken cancellationToken)
    {
        await EnsureDataLoadedAsync(cancellationToken);
        if (string.IsNullOrWhiteSpace(value))
        {
            return _allBorrowers;
        }
        return _allBorrowers.Where(b =>
            b.Name.Contains(value, StringComparison.OrdinalIgnoreCase) ||
            b.Email.Contains(value, StringComparison.OrdinalIgnoreCase));
    }

    private async Task<IEnumerable<Book>> SearchBooksAsync(string value, CancellationToken cancellationToken)
    {
        await EnsureDataLoadedAsync(cancellationToken);
        if (string.IsNullOrWhiteSpace(value))
        {
            return _allBooks;
        }
        return _allBooks.Where(b =>
            b.Title.Contains(value, StringComparison.OrdinalIgnoreCase) ||
            b.Author.Contains(value, StringComparison.OrdinalIgnoreCase));
    }

    private async Task SubmitBorrowingAsync()
    {
        if (_selectedBorrower is null)
        {
            Snackbar.Add("Please select a borrower.", Severity.Warning);
            return;
        }
        if (_selectedBook is null)
        {
            Snackbar.Add("Please select a book.", Severity.Warning);
            return;
        }
        if (_validUntil is null || _validUntil <= DateTime.Today)
        {
            Snackbar.Add("Please select a future due date.", Severity.Warning);
            return;
        }

        var request = new BorrowingRequest
        {
            BorrowerId = _selectedBorrower.Id,
            BookId = _selectedBook.Id,
            ValidUntil = _validUntil.Value
        };

        _submitting = true;
        try
        {
            var client = HttpClientFactory.CreateClient("borrowingService");
            var response = await client.PostAsJsonAsync("/api/cqrs/v1/borrowings", request);
            response.EnsureSuccessStatusCode();
            Snackbar.Add("Borrowing created successfully!", Severity.Success);
            _selectedBorrower = null;
            _selectedBook = null;
            _validUntil = DateTime.Today.AddDays(14);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error creating borrowing: {ex.Message}", Severity.Error);
        }
        finally
        {
            _submitting = false;
        }
    }
}
